{
  "name": "prolaunch-cv-optimizer",
  "version": "2.0.0",
  "description": "ProLaunch Careers AI-powered career tools",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint api/**/*.js server.js --max-warnings 0",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "docker:build": "docker build -t prolaunch-careers .",
    "docker:run": "docker run --env-file .env -p 3000:3000 prolaunch-careers"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.0.2",
    "express": "^4.19.2",
    "formidable": "^3.5.1",
    "mammoth": "^1.7.0",
    "pdf-parse": "^1.1.1",
    "express-prometheus-middleware": "^1.2.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}